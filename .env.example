# ============================================================
# AutoNexus Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=AutoNexus
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_USER=autonexus
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=autonexus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://autonexus:change_me_in_production@postgres:5432/autonexus
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe (Mock / Test Mode) ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ── Rate Limiting (per minute) ───────────────────────────────
RATE_LIMIT_FREE=60
RATE_LIMIT_PRO=300
RATE_LIMIT_ENTERPRISE=1000

# ── Observability ────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_ENABLED=true

# ── Nginx ────────────────────────────────────────────────────
NGINX_HOST=localhost
NGINX_PORT=80
